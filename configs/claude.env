# =============================================================================
# CLAUDE (ANTHROPIC) PROVIDER CONFIGURATION
# =============================================================================
# Set ACTIVE_PROVIDER=claude in .env to use this config.

PROVIDER=claude

# =============================================================================
# ANTHROPIC API KEY
# =============================================================================
# Do NOT set ANTHROPIC_API_KEY here — this file may be committed to git.
# Set it in the root .env file (which is gitignored):
#
#   ANTHROPIC_API_KEY=sk-ant-...
#
# The config loader reads .env first, so the key will be picked up automatically.


# =============================================================================
# RELEVANCE GATE NODE
# Task: Binary YES/NO work-relevance filter
# Model: claude-haiku-4-5 — fastest and cheapest; ideal for simple decisions
# =============================================================================

RELEVANCE_GATE_MODEL_NAME=claude-haiku-4-5-20251001
RELEVANCE_GATE_TEMPERATURE=0.1
RELEVANCE_GATE_MAX_TOKENS=100
RELEVANCE_GATE_TOP_P=0.15
RELEVANCE_GATE_TIMEOUT=60


# =============================================================================
# LOCAL EXTRACTOR NODE
# Task: Structured JSON extraction from a single chunk
# Model: claude-haiku-4-5 — fast, strong instruction-following for JSON output
# =============================================================================

LOCAL_EXTRACTOR_MODEL_NAME=claude-haiku-4-5-20251001
LOCAL_EXTRACTOR_TEMPERATURE=0.2
LOCAL_EXTRACTOR_MAX_TOKENS=2000
LOCAL_EXTRACTOR_TOP_P=0.15
LOCAL_EXTRACTOR_TIMEOUT=120


# =============================================================================
# CONTEXT RESOLVER NODE
# Task: Cross-chunk reasoning, reference resolution, ownership/deadline linking
# Model: claude-sonnet-4-5 — strong reasoning; handles complex multi-step logic
# =============================================================================

CONTEXT_RESOLVER_MODEL_NAME=claude-sonnet-4-5-20250929
CONTEXT_RESOLVER_TEMPERATURE=0.3
CONTEXT_RESOLVER_MAX_TOKENS=4096
CONTEXT_RESOLVER_TOP_P=0.2
CONTEXT_RESOLVER_TIMEOUT=180
CONTEXT_RESOLVER_MAX_SEGMENTS_FOR_LLM=8
CONTEXT_RESOLVER_MAX_PREVIOUS_ACTIONS=5
