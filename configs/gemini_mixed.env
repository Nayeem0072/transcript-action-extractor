# =============================================================================
# GEMINI MIXED PROVIDER CONFIGURATION
# =============================================================================
# Set ACTIVE_PROVIDER=gemini_mixed in .env to use this config.
#
# This config uses a different LLM per node:
#   Relevance Gate    -> Gemini 2.0 Flash Lite  (fast binary filter)
#   Local Extractor   -> Gemini 2.0 Flash        (structured JSON extraction)
#   Context Resolver  -> Claude Haiku 4-5        (cross-chunk reasoning)
#
# API keys are read from .env (gitignored):
#   GOOGLE_API_KEY    -> used by Gemini nodes
#   ANTHROPIC_API_KEY -> used by Claude nodes

# Global provider fallback (used when a node has no per-node PROVIDER override)
PROVIDER=claude


# =============================================================================
# RELEVANCE GATE NODE
# Task: Binary YES/NO work-relevance filter
# Model: gemini-2.0-flash-lite — lowest cost; ideal for simple yes/no decisions
# =============================================================================

RELEVANCE_GATE_PROVIDER=gemini
RELEVANCE_GATE_MODEL_NAME=gemini-2.5-flash-lite
RELEVANCE_GATE_TEMPERATURE=0.1
RELEVANCE_GATE_MAX_TOKENS=100
RELEVANCE_GATE_TOP_P=0.15
RELEVANCE_GATE_TIMEOUT=60


# =============================================================================
# LOCAL EXTRACTOR NODE
# Task: Structured JSON extraction from a single chunk
# Model: gemini-2.0-flash — fast, strong instruction-following for JSON output
# =============================================================================

LOCAL_EXTRACTOR_PROVIDER=gemini
LOCAL_EXTRACTOR_MODEL_NAME=gemini-2.5-flash
LOCAL_EXTRACTOR_TEMPERATURE=0.2
LOCAL_EXTRACTOR_MAX_TOKENS=2000
LOCAL_EXTRACTOR_TOP_P=0.15
LOCAL_EXTRACTOR_TIMEOUT=120


# =============================================================================
# CONTEXT RESOLVER NODE
# Task: Cross-chunk reasoning, reference resolution, ownership/deadline linking
# Model: claude-haiku-4-5 — strong reasoning; handles complex multi-step logic
# =============================================================================

CONTEXT_RESOLVER_PROVIDER=claude
CONTEXT_RESOLVER_MODEL_NAME=claude-haiku-4-5-20251001
CONTEXT_RESOLVER_TEMPERATURE=0.3
CONTEXT_RESOLVER_MAX_TOKENS=4096
CONTEXT_RESOLVER_TOP_P=0.2
CONTEXT_RESOLVER_TIMEOUT=180
CONTEXT_RESOLVER_MAX_SEGMENTS_FOR_LLM=8
CONTEXT_RESOLVER_MAX_PREVIOUS_ACTIONS=5
