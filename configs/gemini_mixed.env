# =============================================================================
# GEMINI MIXED PROVIDER CONFIGURATION
# =============================================================================
# Set ACTIVE_PROVIDER=gemini_mixed in .env to use this config.
#
# Pipeline: segmenter → parallel_extractor → evidence_normalizer
#           → cross_chunk_resolver → global_deduplicator → action_finalizer
#
# LLM nodes:
#   Parallel Extractor  -> Gemini Flash (concurrent structured JSON extraction)
#   Cross-chunk Resolver -> Gemini Flash (single semantic merge + pronoun resolution pass)
#
# API key is read from .env (gitignored):
#   GOOGLE_API_KEY -> used by all Gemini nodes

# Global provider fallback (used when a node has no per-node PROVIDER override)
PROVIDER=claude


# =============================================================================
# LOCAL EXTRACTOR NODE
# Task: Structured JSON extraction from a single chunk
# Model: gemini-2.0-flash — fast, strong instruction-following for JSON output
# =============================================================================

LOCAL_EXTRACTOR_PROVIDER=gemini
LOCAL_EXTRACTOR_MODEL_NAME=gemini-2.5-flash
LOCAL_EXTRACTOR_TEMPERATURE=0.2
LOCAL_EXTRACTOR_MAX_TOKENS=4096
LOCAL_EXTRACTOR_TOP_P=0.15
LOCAL_EXTRACTOR_TIMEOUT=120


# =============================================================================
# CROSS-CHUNK RESOLVER NODE
# Task: Post-extraction semantic merge — identify cross-chunk duplicates and
#       resolve vague references using topic_tags and unresolved_reference signals
# Model: gemini-2.5-flash — same as extractor; handles structured reasoning well
# =============================================================================

CROSS_CHUNK_RESOLVER_PROVIDER=gemini
CROSS_CHUNK_RESOLVER_MODEL_NAME=gemini-2.5-flash
CROSS_CHUNK_RESOLVER_TEMPERATURE=0.2
CROSS_CHUNK_RESOLVER_MAX_TOKENS=4096
CROSS_CHUNK_RESOLVER_TOP_P=0.15
CROSS_CHUNK_RESOLVER_TIMEOUT=120


