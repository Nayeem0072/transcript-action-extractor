# =============================================================================
# ACTIVE PROVIDER SELECTOR
# =============================================================================
# Switch between LLM providers by changing this value.
# Each provider has its own config file in the configs/ directory.
#
# Available providers:
#   gemini_mixed  -> configs/gemini_mixed.env  (Gemini Flash — recommended)
#   claude        -> configs/claude.env        (Claude Haiku — Anthropic API)
#   ollama        -> configs/ollama_glm.env    (local inference — no data leaves machine)
#
# To add a new provider (e.g. GPT), create configs/gpt.env with PROVIDER=openai
# and set ACTIVE_PROVIDER=gpt here.
# =============================================================================

ACTIVE_PROVIDER=gemini_mixed

# =============================================================================
# API KEYS
# =============================================================================
# Only the key for your chosen provider is required.
# Copy this file to .env and fill in the value(s) you need.
# Never commit .env — it is gitignored.

# Google — required when ACTIVE_PROVIDER=gemini_mixed
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic — required when ACTIVE_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama — required when ACTIVE_PROVIDER=ollama
# The value is ignored by Ollama; any non-empty string works.
LANGGRAPH_API_KEY=ollama

# =============================================================================
# ACTION EXECUTOR — MCP SERVER CREDENTIALS
# =============================================================================
# Required only when running the executor in --live mode (run_executor.py --live).
# Each block maps to the corresponding MCP server in mcp_config.json.

# Gmail MCP (@googleapis/mcp-server-gmail)
# Path to OAuth2 credentials JSON downloaded from Google Cloud Console.
GMAIL_OAUTH_PATH=~/.config/gcloud/gmail_oauth.json

# Google Calendar MCP (@googleapis/mcp-server-calendar)
CALENDAR_OAUTH_PATH=~/.config/gcloud/calendar_oauth.json

# Slack MCP (@modelcontextprotocol/server-slack)
# Bot token from https://api.slack.com/apps (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_TEAM_ID=T0000000000

# Notion MCP (@notionhq/notion-mcp-server)
# Integration token from https://www.notion.so/my-integrations
NOTION_API_TOKEN=secret_your-notion-token-here

# Jira MCP (jira-mcp-server)
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=PROJ

# =============================================================================
# JIRA OAUTH (user-level connect flow)
# =============================================================================
# Create an OAuth 2.0 app at https://developer.atlassian.com/console/myapps/
# (Authorization code grants, 3LO). Enable the Jira API product.
#
# JIRA_REDIRECT_URI must be registered as a Callback URL in your Atlassian app
# settings. For local dev, use an ngrok HTTPS tunnel.
# e.g. https://your-static-name.ngrok-free.app/jira/callback
#
# JIRA_FRONTEND_REDIRECT is the frontend URL users land on after connecting.
# e.g. http://localhost:5173/settings?jira=connected
JIRA_CLIENT_ID=your-jira-client-id-here
JIRA_CLIENT_SECRET=your-jira-client-secret-here
JIRA_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/jira/callback
JIRA_FRONTEND_REDIRECT=http://localhost:5173/settings?jira=connected

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Used by the FastAPI API for users, tokens, org contacts, etc.
# Default matches: docker run -e POSTGRES_USER=myuser -e POSTGRES_PASSWORD=mypassword -e POSTGRES_DB=agentdb ...
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@localhost:5432/agentdb

# =============================================================================
# AUTH0 (for frontend login — store user in DB on first request)
# =============================================================================
# Create an API in Auth0 Dashboard and set Identifier as AUTH0_AUDIENCE.
# Domain is your tenant, e.g. dev-xxxx.us.auth0.com (no https://).
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# =============================================================================
# SHARED ORG (development — one org for all users so they share contacts)
# =============================================================================
# When USE_SHARED_ORG=1 (default), every new signup is added to a single org
# named SHARED_ORG_NAME so all users see the same people/teams. Set to 0 for
# production (each user gets their own org).
USE_SHARED_ORG=1
SHARED_ORG_NAME=Development

# =============================================================================
# AUTH0 USERINFO (performance)
# =============================================================================
# When DISABLE_AUTH0_USERINFO=1 (default), the API never calls Auth0 /userinfo.
# It only validates JWTs locally using JWKS and uses whatever claims are present.
# Set to 0 in production if you rely on /userinfo to enrich email/name/picture.
DISABLE_AUTH0_USERINFO=1

# =============================================================================
# SLACK OAUTH (user-level connect flow)
# =============================================================================
# Create a Slack app at https://api.slack.com/apps, then copy the credentials
# from Basic Information → App Credentials.
#
# SLACK_REDIRECT_URI must be registered under OAuth & Permissions → Redirect URLs
# in your Slack app settings. For local dev, use an ngrok HTTPS tunnel.
# e.g. https://your-static-name.ngrok-free.app/slack/callback
#
# SLACK_FRONTEND_REDIRECT is the frontend URL users land on after connecting.
# e.g. http://localhost:5173/settings?slack=connected
SLACK_CLIENT_ID=your-slack-client-id-here
SLACK_CLIENT_SECRET=your-slack-client-secret-here
SLACK_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/slack/callback
SLACK_FRONTEND_REDIRECT=http://localhost:5173/settings?slack=connected

# =============================================================================
# NOTION OAUTH (user-level connect flow)
# =============================================================================
# Create a public Notion integration at https://www.notion.so/my-integrations
# and set its type to "Public". Copy the OAuth client ID and secret from the
# integration's "OAuth Domain & URIs" settings.
#
# NOTION_REDIRECT_URI must be registered as an "Redirect URIs" in your Notion
# integration settings. For local dev, use an ngrok HTTPS tunnel.
# e.g. https://your-static-name.ngrok-free.app/notion/callback
#
# NOTION_FRONTEND_REDIRECT is the frontend URL users land on after connecting.
# e.g. http://localhost:5173/settings?notion=connected
NOTION_CLIENT_ID=your-notion-oauth-client-id-here
NOTION_CLIENT_SECRET=your-notion-oauth-client-secret-here
NOTION_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/notion/callback
NOTION_FRONTEND_REDIRECT=http://localhost:5173/settings?notion=connected

# =============================================================================
# GOOGLE CALENDAR OAUTH (user-level connect flow)
# =============================================================================
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (Application type: Web application). Enable the Google Calendar API for your project.
#
# GOOGLE_CALENDAR_REDIRECT_URI must be added to "Authorised redirect URIs" in the
# OAuth client settings. For local dev, use an ngrok HTTPS tunnel.
# e.g. https://your-static-name.ngrok-free.app/calendar/callback
#
# CALENDAR_FRONTEND_REDIRECT is the frontend URL users land on after connecting.
# e.g. http://localhost:5173/settings?calendar=connected
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-here
GOOGLE_CALENDAR_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/calendar/callback
CALENDAR_FRONTEND_REDIRECT=http://localhost:5173/settings?calendar=connected
